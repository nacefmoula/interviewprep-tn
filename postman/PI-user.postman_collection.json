    {
      "name": "Backend service token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.environment.set(\"service_access_token\", json.access_token);",
              "",
              "pm.test(\"access_token exists\", function () {",
              "  pm.expect(json.access_token).to.exist;",
