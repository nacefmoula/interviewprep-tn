# =============================================================================
# Pi-CloudDOOM — local development environment
# Copy this file to `.env` (same directory) and edit values as needed:
#   cp infra/.env.example infra/.env
#
# IMPORTANT — Postgres password & data volume
# -------------------------------------------------------------------------
# POSTGRES_PASSWORD is baked into the postgres data volume on the FIRST
# `docker compose up`. After that, changing this value here has NO effect on
# the postgres user's actual password (the postgres image only honors it on
# initial volume creation).
#
# If your stack worked before but auth suddenly fails with
#   "FATAL: password authentication failed for user postgres"
# the volume password and the .env value have drifted. Two options:
#   1) Set this value to whatever the volume was initialized with, or
#   2) Wipe the volume (LOSES DATA): docker compose down -v
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=userdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=change_me_dev_only

# --- Kafka / Zookeeper ---
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# --- Keycloak ---
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_dev_only
KC_REALM_NAME=myapp-realm

# --- Services ---
USER_SERVICE_PORT=8081

# --- Frontend ---
FRONTEND_PORT=4200

# --- Spring Boot defaults (consumed by Spring services) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/userdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me_dev_only
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=change_me_dev_only
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/myapp-realm
KEYCLOAK_JWK_SET_URI=http://localhost:8080/realms/myapp-realm/protocol/openid-connect/certs

# --- Mail (Mailtrap sandbox by default) ---
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_EMAIL_FROM=no-reply@pi-clouddoom.local

# --- AI providers ---
#
# ⚠ GROQ_API_KEY is REQUIRED. interview-service and community-service refuse
# to start without it (interview question generator + company review summarizer).
# Get a free key at https://console.groq.com/keys and paste it below.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google AI Studio / Gemini — REQUIRED for the Training Coach chatbot.
# Without it the coach button stays disabled (no service crash).
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
GOOGLE_AI_FALLBACK_MODELS=gemini-flash-lite-latest
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_AI_TEMPERATURE=0.4
GOOGLE_AI_MAX_OUTPUT_TOKENS=600

# Legacy Gemini key (deprecated, kept for backwards compat)
GEMINI_API_KEY=
