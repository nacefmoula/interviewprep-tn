SERVER_PORT=8087
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/resourcedb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=devpassword
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=devpassword
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KEYCLOAK_ISSUER_URI=http://localhost:8090/realms/myapp-realm
KEYCLOAK_JWK_SET_URI=http://localhost:8090/realms/myapp-realm/protocol/openid-connect/certs
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resource-library

# AI generation (optional)
AI_PROVIDER=stub # stub | ollama | openai
AI_DEFAULT_COUNT=5
AI_FALLBACK_TO_STUB=true
AI_SCHEDULE_ENABLED=false
AI_CRON=0 0 3 * * *
AI_BATCH_SIZE=5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_MS=20000

# Auto-seed on startup (optional)
AI_AUTOSEED_ENABLED=true
AI_AUTOSEED_CATEGORY_COUNT=18
AI_AUTOSEED_RESOURCES_PER_CATEGORY=4

# Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=20000
